# Build context is the PARENT directory (containing corpus-core/,
# arxiv-radar-mcp/, lab-corpus-mcp/) — entries below apply at that root.

# Per-repo developer junk
**/.venv/
**/.cache/
**/.git/
**/.github/
**/.claude/
**/tmp/
**/docs/
**/tests/
**/.pytest_cache/
**/.ruff_cache/
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/build/
**/dist/
**/*.log
**/*.swp
**/.DS_Store
**/Thumbs.db

# Personal corpora (don't ship into the image)
literature/
parsed/
sources/
